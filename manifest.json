{
  "manifest_version": 3,
  "name": "Notch",
  "version": "1.0.0",
  "description": "Save bookmarks with screenshots to your Notion databases",
  "permissions": ["tabs", "storage", "activeTab", "scripting"],
  "host_permissions": ["https://api.notion.com/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
